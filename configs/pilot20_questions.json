{
  "name": "pilot20",
  "version": "0.1",
  "purpose": "Small, train-only pilot generation set used to verify answer quality and span-label feasibility before running the full 100-question generation.",
  "selection_policy": {
    "split": "train_only",
    "record_count": 20,
    "requirements": [
      "cover all seven MVP question types",
      "include the five qwen_batch5 smoke-test questions as anchors",
      "include easy, medium, and hard examples",
      "include product, country, arithmetic, ranking, share, and return/cancellation reasoning",
      "avoid dev and test records so threshold tuning and final evaluation remain clean"
    ]
  },
  "question_ids": [
